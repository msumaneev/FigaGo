[
  {
    "name": "Сообщить",
    "name_en": "Message",
    "syntax": "Сообщить(ТекстСообщения, Статус)",
    "params": [
      {"name": "ТекстСообщения", "required": true, "description": "Текст выводимого сообщения"},
      {"name": "Статус", "required": false, "description": "Статус сообщения: СтатусСообщения.Важное, .Обычное, .Информация и т.д."}
    ],
    "returns": "Нет возвращаемого значения (процедура)",
    "example": "Сообщить(\"Документ проведён!\", СтатусСообщения.Информация);"
  },
  {
    "name": "СтрНайти",
    "name_en": "StrFind",
    "syntax": "СтрНайти(Строка, ПодстрокаПоиска, НаправлениеПоиска, НачальнаяПозиция, НомерВхождения)",
    "params": [
      {"name": "Строка", "required": true, "description": "Исходная строка, в которой осуществляется поиск"},
      {"name": "ПодстрокаПоиска", "required": true, "description": "Искомая подстрока"},
      {"name": "НаправлениеПоиска", "required": false, "description": "НаправлениеПоиска.СНачала (по умолчанию) или НаправлениеПоиска.СКонца"},
      {"name": "НачальнаяПозиция", "required": false, "description": "Позиция символа, с которого начинается поиск (по умолч. 0 — с начала)"},
      {"name": "НомерВхождения", "required": false, "description": "Номер искомого вхождения (по умолч. 1)"}
    ],
    "returns": "Число — позиция первого символа найденной подстроки. 0 — если не найдена.",
    "example": "Позиция = СтрНайти(\"Привет, мир!\", \"мир\"); // Результат: 9"
  },
  {
    "name": "Формат",
    "name_en": "Format",
    "syntax": "Формат(Значение, ФорматнаяСтрока)",
    "params": [
      {"name": "Значение", "required": true, "description": "Значение, которое нужно отформатировать (Число, Дата, Булево)"},
      {"name": "ФорматнаяСтрока", "required": true, "description": "Строка форматирования, например: \"ЧЦ=10; ЧДЦ=2\" или \"ДФ=dd.MM.yyyy\""}
    ],
    "returns": "Строка — отформатированное представление значения",
    "example": "Результат = Формат(12345.67, \"ЧЦ=10; ЧДЦ=2; ЧРД=.\"); // \"  12345.67\""
  },
  {
    "name": "ЗначениеЗаполнено",
    "name_en": "ValueIsFilled",
    "syntax": "ЗначениеЗаполнено(Значение)",
    "params": [
      {"name": "Значение", "required": true, "description": "Проверяемое значение (ссылка, строка, число, дата, булево)"}
    ],
    "returns": "Булево — Истина, если значение отличается от значения по умолчанию данного типа",
    "example": "Если ЗначениеЗаполнено(Контрагент) Тогда\n    // обработка\nКонецЕсли;"
  },
  {
    "name": "СтрЗаменить",
    "name_en": "StrReplace",
    "syntax": "СтрЗаменить(Строка, ПодстрокаПоиска, ПодстрокаЗамены)",
    "params": [
      {"name": "Строка", "required": true, "description": "Исходная строка"},
      {"name": "ПодстрокаПоиска", "required": true, "description": "Подстрока, которую нужно заменить"},
      {"name": "ПодстрокаЗамены", "required": true, "description": "Подстрока, на которую заменяется"}
    ],
    "returns": "Строка — результат замены всех вхождений",
    "example": "Рез = СтрЗаменить(\"2026-03-12\", \"-\", \".\"); // \"2026.03.12\""
  },
  {
    "name": "Лев",
    "name_en": "Left",
    "syntax": "Лев(Строка, ЧислоСимволов)",
    "params": [
      {"name": "Строка", "required": true, "description": "Исходная строка"},
      {"name": "ЧислоСимволов", "required": true, "description": "Количество символов с начала строки"}
    ],
    "returns": "Строка — левая часть строки указанной длины",
    "example": "Рез = Лев(\"Привет\", 3); // \"При\""
  },
  {
    "name": "Прав",
    "name_en": "Right",
    "syntax": "Прав(Строка, ЧислоСимволов)",
    "params": [
      {"name": "Строка", "required": true, "description": "Исходная строка"},
      {"name": "ЧислоСимволов", "required": true, "description": "Количество символов с конца строки"}
    ],
    "returns": "Строка — правая часть строки указанной длины",
    "example": "Рез = Прав(\"Привет\", 3); // \"вет\""
  },
  {
    "name": "Сред",
    "name_en": "Mid",
    "syntax": "Сред(Строка, НачальныйНомер, ЧислоСимволов)",
    "params": [
      {"name": "Строка", "required": true, "description": "Исходная строка"},
      {"name": "НачальныйНомер", "required": true, "description": "Позиция символа, с которого начинается выделение (нумерация с 1)"},
      {"name": "ЧислоСимволов", "required": false, "description": "Количество выделяемых символов. Если не указано — до конца строки"}
    ],
    "returns": "Строка — подстрока",
    "example": "Рез = Сред(\"Привет, мир!\", 9, 3); // \"мир\""
  },
  {
    "name": "СтрДлина",
    "name_en": "StrLen",
    "syntax": "СтрДлина(Строка)",
    "params": [
      {"name": "Строка", "required": true, "description": "Строка, длину которой нужно определить"}
    ],
    "returns": "Число — количество символов в строке",
    "example": "Длина = СтрДлина(\"Привет\"); // 6"
  },
  {
    "name": "Число",
    "name_en": "Number",
    "syntax": "Число(Значение)",
    "params": [
      {"name": "Значение", "required": true, "description": "Значение, преобразуемое к числу (Строка, Булево)"}
    ],
    "returns": "Число — результат преобразования",
    "example": "Рез = Число(\"123.45\"); // 123.45"
  },
  {
    "name": "Строка",
    "name_en": "String",
    "syntax": "Строка(Значение)",
    "params": [
      {"name": "Значение", "required": true, "description": "Значение любого типа, преобразуемое в строковое представление"}
    ],
    "returns": "Строка — строковое представление значения",
    "example": "Рез = Строка(12345); // \"12 345\" (с учётом локали)"
  },
  {
    "name": "Дата",
    "name_en": "Date",
    "syntax": "Дата(Год, Месяц, День, Час, Минута, Секунда) или Дата(Строка)",
    "params": [
      {"name": "Год", "required": true, "description": "Год (число) или строка формата \"ГГГГММДДЧЧммсс\""},
      {"name": "Месяц", "required": false, "description": "Месяц (число)"},
      {"name": "День", "required": false, "description": "День (число)"},
      {"name": "Час", "required": false, "description": "Час (число, по умолч. 0)"},
      {"name": "Минута", "required": false, "description": "Минута (число, по умолч. 0)"},
      {"name": "Секунда", "required": false, "description": "Секунда (число, по умолч. 0)"}
    ],
    "returns": "Дата — значение типа Дата",
    "example": "Д = Дата(2026, 3, 12); // 12.03.2026\nД2 = Дата(\"20260312\"); // 12.03.2026"
  },
  {
    "name": "ТекущаяДата",
    "name_en": "CurrentDate",
    "syntax": "ТекущаяДата()",
    "params": [],
    "returns": "Дата — текущая дата и время сервера (или клиента, в зависимости от контекста)",
    "example": "Сейчас = ТекущаяДата();"
  },
  {
    "name": "НачалоДня",
    "name_en": "BegOfDay",
    "syntax": "НачалоДня(Дата)",
    "params": [
      {"name": "Дата", "required": true, "description": "Исходная дата"}
    ],
    "returns": "Дата — дата с временем 00:00:00",
    "example": "НД = НачалоДня(ТекущаяДата()); // 12.03.2026 0:00:00"
  },
  {
    "name": "КонецДня",
    "name_en": "EndOfDay",
    "syntax": "КонецДня(Дата)",
    "params": [
      {"name": "Дата", "required": true, "description": "Исходная дата"}
    ],
    "returns": "Дата — дата с временем 23:59:59",
    "example": "КД = КонецДня(ТекущаяДата()); // 12.03.2026 23:59:59"
  },
  {
    "name": "СокрЛП",
    "name_en": "TrimAll",
    "syntax": "СокрЛП(Строка)",
    "params": [
      {"name": "Строка", "required": true, "description": "Строка, из которой нужно удалить пробелы слева и справа"}
    ],
    "returns": "Строка — строка без начальных и конечных пробелов",
    "example": "Рез = СокрЛП(\"  Привет  \"); // \"Привет\""
  },
  {
    "name": "ВРег",
    "name_en": "Upper",
    "syntax": "ВРег(Строка)",
    "params": [
      {"name": "Строка", "required": true, "description": "Строка для перевода в верхний регистр"}
    ],
    "returns": "Строка — строка в верхнем регистре",
    "example": "Рез = ВРег(\"Привет\"); // \"ПРИВЕТ\""
  },
  {
    "name": "НРег",
    "name_en": "Lower",
    "syntax": "НРег(Строка)",
    "params": [
      {"name": "Строка", "required": true, "description": "Строка для перевода в нижний регистр"}
    ],
    "returns": "Строка — строка в нижнем регистре",
    "example": "Рез = НРег(\"Привет\"); // \"привет\""
  },
  {
    "name": "ТипЗнч",
    "name_en": "TypeOf",
    "syntax": "ТипЗнч(Значение)",
    "params": [
      {"name": "Значение", "required": true, "description": "Значение, тип которого нужно определить"}
    ],
    "returns": "Тип — тип переданного значения",
    "example": "Если ТипЗнч(Значение) = Тип(\"Строка\") Тогда\n    // это строка\nКонецЕсли;"
  },
  {
    "name": "СтрРазделить",
    "name_en": "StrSplit",
    "syntax": "СтрРазделить(Строка, Разделитель, ВключатьПустые)",
    "params": [
      {"name": "Строка", "required": true, "description": "Разделяемая строка"},
      {"name": "Разделитель", "required": true, "description": "Строка-разделитель (один или несколько символов)"},
      {"name": "ВключатьПустые", "required": false, "description": "Булево — включать ли пустые строки в результат (по умолч. Истина)"}
    ],
    "returns": "Массив — массив строк",
    "example": "Части = СтрРазделить(\"один,два,три\", \",\"); // Массив: [\"один\", \"два\", \"три\"]"
  }
]
